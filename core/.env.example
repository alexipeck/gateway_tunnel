# ZeroTier network settings
ZT_NETWORK_ID=8056c2e21c000001

# Core app IP(s), comma-separated. Per-port IP: 32400/tcp@172.18.0.10 in FORWARD_PORTS
CORE_APP_IP=172.18.0.10

# Optional override if route-based detection is not desired
CORE_APP_IFACE=

# Comma-separated entries: ZT_PORT[:APP_PORT]/PROTO
FORWARD_PORTS=32400/tcp,2456/udp

# app_net subnet and static IP for this gateway container
APP_NETWORK_SUBNET=172.18.0.0/24
GATEWAY_CONTAINER_IP=172.18.0.2

RULE_REAPPLY_INTERVAL=30
CORE_ZT_READY_TIMEOUT=300
