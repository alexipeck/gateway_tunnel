<?xml version="1.0"?>
<Container version="2">
  <Name>zt-core-gateway</Name>
  <Registry>https://ghcr.io</Registry>
  <Repository>ghcr.io/alexipeck/gateway_tunnel:latest</Repository>
  <Github>https://github.com/alexipeck/gateway_tunnel</Github>
  <Network>bridge</Network>
  <MyIP/>
  <Privileged>false</Privileged>
  <Support>https://github.com/alexipeck/gateway_tunnel</Support>
  <Project/>
  <Overview>ZeroTier tunnel gateway (core). Receives traffic from edge over ZeroTier and forwards to your app container.</Overview>
  <Category>Network:</Category>
  <WebUI/>
  <TemplateURL/>
  <Icon/>
  <ExtraParams>--cap-add=NET_ADMIN --device /dev/net/tun:/dev/net/tun --sysctl net.ipv4.ip_forward=1 --entrypoint "/bin/bash"</ExtraParams>
  <PostArgs>/entrypoint.sh</PostArgs>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <DonateImg/>
  <MinVer/>
  <Description>Core side of ZeroTier tunnel. Set CORE_APP_IP to app container IP(s), comma-separated. Use @IP in FORWARD_PORTS for per-port targets (e.g. 32400/tcp@172.18.0.10).</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish/>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/gateway_tunnel/core/zerotier-one</HostDir>
      <ContainerDir>/var/lib/zerotier-one</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/gateway_tunnel/core/entrypoint.sh</HostDir>
      <ContainerDir>/entrypoint.sh</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
  </Data>
  <Environment/>
  <Labels/>
  <Config Name="ZT_NETWORK_ID" Target="ZT_NETWORK_ID" Default="" Mode="" Description="ZeroTier network ID" Type="Variable" Display="always" Required="true" Mask="false"></Config>
  <Config Name="CORE_APP_IP" Target="CORE_APP_IP" Default="" Mode="" Description="App IP(s), comma-separated. Use 127.0.0.1 when app shares core network" Type="Variable" Display="always" Required="true" Mask="false"></Config>
  <Config Name="EDGE_NODE_ZT_IP" Target="EDGE_NODE_ZT_IP" Default="" Mode="" Description="Edge ZeroTier IP - routes outbound through edge when set" Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="FORWARD_PORTS" Target="FORWARD_PORTS" Default="32400/tcp,2456/udp" Mode="" Description="Ports to forward (e.g. 32400/tcp,2456/udp or 32400/tcp@172.18.0.10 for per-port IP)" Type="Variable" Display="always" Required="true" Mask="false">32400/tcp,2456/udp</Config>
  <Config Name="zerotier-one" Target="/var/lib/zerotier-one" Default="/mnt/user/appdata/gateway_tunnel/core/zerotier-one" Mode="rw" Description="ZeroTier identity persistence" Type="Path" Display="advanced-hide" Required="true" Mask="false">/mnt/user/appdata/gateway_tunnel/core/zerotier-one</Config>
  <Config Name="entrypoint.sh" Target="/entrypoint.sh" Default="/mnt/user/appdata/gateway_tunnel/core/entrypoint.sh" Mode="ro" Description="Entrypoint script" Type="Path" Display="advanced-hide" Required="true" Mask="false">/mnt/user/appdata/gateway_tunnel/core/entrypoint.sh</Config>
</Container>
