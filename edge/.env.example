# ZeroTier network settings
ZT_NETWORK_ID=8056c2e21c000001
ZT_SUBNET=10.147.17.0/24

# ZeroTier IP of the core node container member
CORE_NODE_ZT_IP=10.147.17.3

# Comma-separated entries: PUBLIC_PORT[:TARGET_PORT]/PROTO
FORWARD_PORTS=32400/tcp,2456/udp

# Leave empty to auto-detect default route interface inside container
EXT_IFACE=

RULE_REAPPLY_INTERVAL=30
CORE_NODE_WAIT_TIMEOUT=300
